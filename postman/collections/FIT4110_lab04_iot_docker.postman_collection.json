    },
    {
      "name": "01_Functional - POST readings returns 201",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer local-dev-token", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"esp32-lab-a101\",\n  \"metric\": \"temperature\",\n  \"value\": 31.5,\n  \"unit\": \"celsius\",\n  \"timestamp\": \"2026-05-13T08:30:00+07:00\"\n}"
        },
        "url": { "raw": "http://127.0.0", "protocol": "http", "host": ["127", "0", "0", "1"], "port": "8001", "path": ["readings"] }
      }
    },
    {
      "name": "01_Functional - GET latest readings returns 200",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer local-dev-token", "type": "text" }
        ],
        "url": { "raw": "http://127.0.0/latest?device_id=esp32-lab-a101&limit=5", "protocol": "http", "host": ["127", "0", "0", "1"], "port": "8001", "path": ["readings", "latest"], "query": [{ "key": "device_id", "value": "esp32-lab-a101" }, { "key": "limit", "value": "5" }] }
      }
    }
  ]
