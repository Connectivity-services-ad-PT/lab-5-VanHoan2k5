{
  "info": {
    "name": "FIT4110 Lab 05 Auto Verification - Group B1",
    "schema": "https://getpostman.com"
  },
  "item": [
    {
      "name": "01_Functional - GET health returns 200",
      "request": {
        "method": "GET",
        "url": { "raw": "http://localhost:8000/health", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["health"] }
      }
    },
    {
      "name": "01_Functional - POST readings returns 201",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer local-dev-token", "type": "text" },
          { "key": "Content-Type", "value": "application/json", "type": "text" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"esp32-b101\",\n  \"temperature\": 31.5,\n  \"humidity\": 72.0,\n  \"motion\": true,\n  \"timestamp\": \"2026-05-02T09:00:00Z\"\n}"
        },
        "url": { "raw": "http://localhost:8000/readings", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["readings"] }
      }
    },
    {
      "name": "01_Functional - GET latest readings returns 200",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer local-dev-token", "type": "text" }
        ],
        "url": { "raw": "http://localhost:8000/readings/latest?device_id=esp32-b101&limit=5", "protocol": "http", "host": ["localhost"], "port": "8000", "path": ["readings", "latest"], "query": [{ "key": "device_id", "value": "esp32-b101" }, { "key": "limit", "value": "5" }] }
      }
    }
  ]
}
